permalink: shop-pdp.html
showBreadcrumbs: true
breadcrumbs:
    - Label: Shop
      Target: /shop
    - Label: Produkt
---

{%- from '../../_includes/components/Atoms/Button/Button.njk' import Button %}
{%- from '../../_includes/components/Atoms/Icon/Icon.njk' import IconEmbedded %}
{%- from '../../_includes/components/Atoms/Link/Link.njk' import UtilityLink %}
{%- from '../../_includes/components/Atoms/Chip/Chip.njk' import Chip %}
{%- from '../../_includes/components/Atoms/Heading/Heading.njk' import Heading %}
{%- from '../../_includes/components/Atoms/Paragraph/Paragraph.njk' import Paragraph %}
{%- from '../../_includes/components/Atoms/Image/Image.njk' import Image %}
{%- from '../../_includes/components/Molecules/Rating/Rating.njk' import UneditableRating %}
{%- from '../../_includes/components/Molecules/IconGroup/IconGroup.njk' import IconGroup %}
{%- from '../../_includes/components/Molecules/DownloadField/DownloadField.njk' import DownloadField %}
{%- from '../../_includes/components/Molecules/Table/Table.njk' import StaticTable %}

<div class="pdp">
    <div class="pdp_content">
        <div class="pdp_block">
            <div class="pdp_spacebetween pdp_heading"></div>
            <div class="pdp_image"></div>
            <div class="pdp_spacebetween">
                {{ UneditableRating (FilledStars = '4', Size = 'regular') }}
                {{ Chip ( Style = 'primary', Label = 'Favorit', IconHeart = true ) }}
            </div>
            <div class="pdp_paragraph"></div>
        </div>
        <table class="StaticTable">
            <tbody class="pdp_table"></tbody>
        </table>
        {# <div class="pdp_table">
            {{ StaticTable ( TableRows = [  
        {Head: 'Teefarm', Paragraph: 'At vero eos et accusam duo.'},
        {Head: 'Teefarm', Paragraph: 'At vero eos et accusam duo.'},
        {Head: 'Teefarm', Paragraph: 'At vero eos et accusam duo.'},
        {Head: 'Teefarm', Paragraph: 'At vero eos et accusam duo.'}
        ]) }}
        </div> #}
        <div class="pdp_block">
            {{ UtilityLink(Weight = 'bold') }}
        </div>
        <div class="pdp_buttonwrapper">
            {{ Button (fullWidth = true, Label = 'In den Warenkorb', href = 'cart.html', showIconRight = true, IconContentRight = 'Cart-filled') }}
        </div>
        <div class="pdp_end"></div>
    </div>
</div>

